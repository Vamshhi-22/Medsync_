package com.medsync.auth.service;

import org.springframework.http.ResponseEntity;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.stereotype.Service;
import org.springframework.web.bind.annotation.RequestBody;

import com.medsync.auth.model.User;
import com.medsync.auth.playload.request.SignUpRequest;
import com.medsync.auth.playload.response.SignUpResponse;
import com.medsync.auth.repository.UserRepository;

import jakarta.transaction.Transactional;

@Service
public class AuthService {

	private final UserRepository repository;

	private final PasswordEncoder encoder;

	public AuthService(UserRepository repository, PasswordEncoder encoder) {
		super();
		this.repository = repository;
		this.encoder = encoder;
	}
	
	@Transactional
	public ResponseEntity<SignUpResponse> registerUser(@RequestBody SignUpRequest request) {
		if (repository.existsByUserName(request.getUserName())) {

			return ResponseEntity.badRequest()
					.body(new SignUpResponse(request.getUserName(), "Username alredy exsists"));

		}
		User user = new User(request.getUserName(), request.getEmail(), encoder.encode(request.getPassword()));

		repository.save(user);

		return ResponseEntity.ok(new SignUpResponse(user.getUserName(), " signedup sucessfully"));

	}
}
